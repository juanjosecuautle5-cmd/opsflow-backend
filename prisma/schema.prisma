generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model Organization {
  id    String  @id @default(uuid())
  name  String
  users User[]
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  role           Role          @default(USER)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}